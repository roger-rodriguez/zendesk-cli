{
  "name": "zendesk-cli",
  "version": "1.0.0",
  "description": "",
  "main": "dist/index.js",
  "type": "module",
  "files": [
    "dist"
  ],
  "bin": {
    "zd": "./dist/index.js"
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --banner:js=\"import { createRequire } from 'node:module'; const require = createRequire(import.meta.url);\" --outfile=dist/index.js && chmod +x dist/index.js",
    "prepare": "npm run build",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "format": "prettier --write \"./src/**/*.{js,ts,md}\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "dotenv": "17.2.1",
    "glob": "11.0.3",
    "zod": "4.0.17"
  },
  "devDependencies": {
    "@types/node": "22.13.13",
    "esbuild": "^0.25.12",
    "prettier": "3.6.2",
    "tsconfig-paths": "4.2.0",
    "tsx": "^4.20.4",
    "typescript": "5.9.2",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "volta": {
    "node": "22.13.1"
  }
}
